          "hidden_layer_sizes": [
            128,
            64
          ],
          "alpha": 0.0001
        },
        "logistic_regression": {
          "weight_decay": 5.0
        },
        "decision_tree": {
          "depth": 5
        },
        "knn": {
          "k": 5
        },
        "svm": {
          "C": 1.0,
          "kernel": "linear",
          "gamma": "auto"
        },
        "random_forest": {
          "n_estimators": 100,
          "depth": 10,
          "max_features": "sqrt",
