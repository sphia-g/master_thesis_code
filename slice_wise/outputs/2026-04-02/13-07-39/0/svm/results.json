          "svm",
          "tabpfn"
        ],
        "type": "mlp",
        "mlp": {
          "hidden_layer_sizes": [
            128,
            64
          ],
          "alpha": 0.0001
        },
        "logistic_regression": {
          "weight_decay": 5.0
        },
        "decision_tree": {
          "depth": 5
        },
        "knn": {
          "k": 5
        },
        "svm": {
          "C": 1.0,
          "kernel": "linear",
          "gamma": "auto"
        },
        "random_forest": {
          "n_estimators": 100,
          "depth": 10,
          "max_features": "sqrt",
          "bootstrap": true
        },
        "gmm": {
          "n_components_per_class": 3,
          "covariance_type": "diag",
          "max_iter": 100,
          "tol": 0.001,
          "reg_covar": 1e-06
        },
        "majority": {},
        "tabpfn": {
          "batch_size": 5000,
          "ignore_pretraining_limits": true
        }
      }
    },
    "patient_aggregation": "majority",
    "mil": {
      "epochs": 50,
