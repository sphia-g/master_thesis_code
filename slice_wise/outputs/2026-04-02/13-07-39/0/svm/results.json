    "data": {
      "random_state": 42,
      "n_folds": 5
    },
    "features": {
      "tumor_only": true,
      "naive40": {
        "feature_cols": [
          "ADC",
          "ADC_K",
          "Darkfluid",
          "PET_late",
          "T1_mprage",
          "T1_mprageKM",
          "T2",
          "PET_dynamic",
          "PETwashinslope",
          "PETwashin_intercept",
          "PETwashoutslope",
          "PETwashout_intercept",
          "PETIntegral",
          "PET_TTP"
        ]
      },
      "brats": {
        "feature_cols": [
          "flair",
          "t1",
          "t1ce",
          "t2"
        ]
      },
      "planes": [
        "axial",
        "coronal",
        "sagittal"
      ],
      "min_tumor_pixels": 50,
      "target_size": 224
    },
    "model": {
      "type": "modular_cnn",
      "modular_cnn": {
        "adapter_out_channels": 3,
        "backbone": "resnet34",
        "pretrained": true,
