        "mlp": {
          "hidden_layer_sizes": [
            128,
            64
          ],
          "alpha": 0.0001
        },
        "logistic_regression": {
          "weight_decay": 5.0
        },
        "decision_tree": {
          "depth": 5
        },
        "knn": {
          "k": 5
        },
        "svm": {
