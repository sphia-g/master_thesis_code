          "T1_mprageKM",
          "T2",
          "PET_dynamic",
          "PETwashinslope",
          "PETwashin_intercept",
          "PETwashoutslope",
          "PETwashout_intercept",
          "PETIntegral",
          "PET_TTP"
        ]
      },
      "brats": {
        "feature_cols": [
          "flair",
          "t1",
          "t1ce",
          "t2"
        ]
      },
      "planes": [
        "axial",
        "coronal",
        "sagittal"
      ],
      "min_tumor_pixels": 50,
      "target_size": 224
    },
    "model": {
      "type": "modular_cnn",
      "modular_cnn": {
        "adapter_out_channels": 3,
